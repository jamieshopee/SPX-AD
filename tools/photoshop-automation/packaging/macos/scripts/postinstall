#!/bin/zsh

set -u

LAUNCH_AGENT="/Library/LaunchAgents/com.spxad.helper.plist"
APP_PATH="/Applications/SPX Helper.app"

/usr/sbin/chown root:wheel "$LAUNCH_AGENT"
/bin/chmod 0644 "$LAUNCH_AGENT"

CONSOLE_USER=$(/usr/bin/stat -f "%Su" /dev/console)
if [[ -z "$CONSOLE_USER" || "$CONSOLE_USER" == "root" || "$CONSOLE_USER" == "loginwindow" ]]; then
  exit 0
fi

CONSOLE_UID=$(/usr/bin/id -u "$CONSOLE_USER")

# Register the login lifecycle in the active Aqua session. RunAtLoad starts
# the Helper immediately on a fresh install; `open` is a safe fallback if the
# agent was already registered by an interrupted installer retry.
/bin/launchctl asuser "$CONSOLE_UID" /bin/launchctl bootstrap \
  "gui/$CONSOLE_UID" "$LAUNCH_AGENT" >/dev/null 2>&1 || true
/bin/launchctl asuser "$CONSOLE_UID" /usr/bin/open "$APP_PATH" >/dev/null 2>&1 || true

exit 0
